<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Account Water</title>

  <link rel="stylesheet" href="/css/manageBill.css">
</head>
<body>

  <!-- TOPBAR -->
  <%- include('../../../partials/adminTopbar', { title: title }) %>

  <div class="container">

    <!-- SIDEBAR -->
    <%- include('../../../partials/adminSidebar', { page: 'memberships' }) %>

    <!-- MAIN CONTENT -->
    <div class="main">
      <div class="wrapper">

        <!-- TOP BAR -->
        <div class="top-bar">
          <div class="search">
            <input type="text" id="searchInput" placeholder="Search">
            <button>🔍</button>
          </div>

          <div class="filters">
            <select>
              <option>Village: All</option>
            </select>

            <select>
              <option>Block: All</option>
            </select>

            <select>
              <option>Archives: All</option>
            </select>
          </div>
        </div>

        <!-- DATE / TIME -->
        <div class="date-time">
          <input type="date" id="dateInput">
          <input type="time" id="timeInput">
        </div>

<!-- STATUS CARDS -->
<div class="status-row">

  <a href="/admin/bills/water/manageWater?tab=unpaid"
     style="text-decoration:none; color:inherit;">
    <div class="status unpaid <%= tab === 'unpaid' ? 'active' : '' %>">
      <span><%= unpaidCount %></span> Unpaid for this Month
    </div>
  </a>

  <a href="/admin/bills/water/manageWater?tab=approval"
     style="text-decoration:none; color:inherit;">
    <div class="status approval <%= tab === 'approval' ? 'active' : '' %>">
      <span><%= approvalCount %></span> For Payment Approval
    </div>
  </a>

  <a href="/admin/bills/water/manageWater?tab=due"
     style="text-decoration:none; color:inherit;">
    <div class="status due <%= tab === 'due' ? 'active' : '' %>">
      <span><%= dueCount %></span> Due Bills
    </div>
  </a>

  <a href="/admin/bills/water/manageWater?tab=completed"
     style="text-decoration:none; color:inherit;">
    <div class="status completed <%= tab === 'completed' ? 'active' : '' %>">
      <span><%= completedCount %></span> Payment Completed
    </div>
  </a>

</div>
<!-- VIEW PANEL (hidden by default) -->
<div class="view-panel" id="viewPanel" style="display:none; margin-bottom:20px;">
  <button
    type="button"
    onclick="closeView()"
    style="margin-bottom:15px; padding:8px 16px; cursor:pointer;">
    ← Back to Table
  </button>

  <div id="viewContent"></div>
</div>
        <!-- TABLE -->
        <div class="table-box">
          <table>
            <thead>
              <tr>
                <th>Due Date</th>
                <th>Amount</th>
                <th>H.O Ref No.</th>
                <th>Name</th>
                <th>Email</th>
                <th>Village</th>
                <th>Block</th>
                <th>Actions</th>
              </tr>
            </thead>

<tbody id="tableBody">

  <!-- PAYMENT APPROVAL TAB -->
  <% if (tab === 'approval') { %>

    <% if (!payments || payments.length === 0) { %>
      <tr>
        <td colspan="8" style="text-align:center;">
          No payments pending approval.
        </td>
      </tr>
    <% } %>

    <% payments.forEach(payment => { %>
      <% const bill = payment.bill; %>
      <% const user = payment.user; %>

      <% if (bill && user) { %>
        <tr>
          <td>
            <%= new Date(bill.dueDate).toLocaleDateString('en-US') %>
          </td>
          <td>
            ₱ <%= Number(bill.amount || 0).toFixed(2) %>
          </td>
          <td>
            <%= user.referenceNumber || '-' %>
          </td>
          <td>
            <%= user.givenName %> <%= user.surname %>
          </td>
          <td>
            <%= user.email %>
          </td>
          <td>
            <%= user.village || '-' %>
          </td>
          <td>
            <%= user.blockLot || '-' %>
          </td>
          <td>
            <div class="actions">
              <div class="action">
                <img src="/img/pin.png">
              </div>
              <div class="action">
                <img src="/img/notif.png">
              </div>
<div class="action"
     style="cursor: pointer;"
     onclick='openView(
       "<%= user.referenceNumber || "-" %>",
       "<%= new Date(bill.dueDate).toLocaleDateString("en-US", {
         year: "numeric",
         month: "long",
         day: "numeric"
       }) %>",
       "<%= Number(bill.amount || 0).toFixed(2) %>",
       "<%= bill.file || "" %>",
       true,
       "<%= payment.receipt || "" %>",
       "<%= payment._id %>"
     )'>
  <img src="/img/view.png" style="cursor: pointer;">
</div>
            </div>
          </td>
        </tr>
      <% } %>
    <% }) %>


  <!-- OTHER TABS (UNPAID, DUE, COMPLETED) -->
  <% } else { %>

    <% if (!bills || bills.length === 0) { %>
      <tr>
        <td colspan="8" style="text-align:center;">
          No records found.
        </td>
      </tr>
    <% } %>

    <% bills.forEach(bill => { %>
      <% const user = bill.user; %>

      <% if (user) { %>
        <tr>
          <td>
            <%= new Date(
              tab === 'completed' && bill.paidAt
                ? bill.paidAt
                : bill.dueDate
            ).toLocaleDateString('en-US') %>
          </td>

          <td>
            ₱ <%= Number(bill.amount || 0).toFixed(2) %>
          </td>

          <td>
            <%= user.referenceNumber || '-' %>
          </td>

          <td>
            <%= user.givenName %> <%= user.surname %>
          </td>

          <td>
            <%= user.email %>
          </td>

          <td>
            <%= user.village || '-' %>
          </td>

          <td>
            <%= user.blockLot || '-' %>
          </td>

          <td>
            <div class="actions">
              <div class="action">
                <img src="/img/pin.png">
              </div>
              <div class="action">
                <img src="/img/notif.png">
              </div>
<div class="action"
     style="cursor: pointer;"
     onclick='openView(
       "<%= user.referenceNumber || "-" %>",
       "<%= new Date(bill.dueDate).toLocaleDateString("en-US", {
         year: "numeric",
         month: "long",
         day: "numeric"
       }) %>",
       "<%= Number(bill.amount || 0).toFixed(2) %>",
       "<%= bill.file || "" %>"
     )'>
  <img src="/img/view.png">
</div>
            </div>
          </td>
        </tr>
      <% } %>
    <% }) %>

  <% } %>

</tbody>
        </div>

      </div>
    </div>
  </div>

<script>
  function openView(
    referenceNumber,
    dueDate,
    amount,
    file,
    isApproval = false,
    receipt = '',
    paymentId = ''
  ) {
    const viewPanel = document.getElementById('viewPanel');
    const viewContent = document.getElementById('viewContent');
    const tableBox = document.querySelector('.table-box');

    let approvalSection = '';

    if (isApproval) {
      approvalSection = `
        <div style="margin-top: 30px;">
          <h3 style="margin-bottom: 15px;">Payment Receipt</h3>

          ${
            receipt
              ? `
                <a href="/uploads/waterReceipts/${receipt}" target="_blank">
                  <iframe
                    src="/uploads/waterReceipts/${receipt}#toolbar=0&navpanes=0&scrollbar=0"
                    width="250"
                    height="250"
                    style="
                      border:none;
                      border-radius:12px;
                      background:white;
                      box-shadow:0 4px 10px rgba(0,0,0,0.15);
                      display:block;
                    ">
                  </iframe>
                </a>
              `
              : '<p>No receipt uploaded.</p>'
          }

          <div style="margin-top: 20px; display: flex; gap: 10px;">
            <button
              type="button"
              style="
                padding: 10px 20px;
                background: #28a745;
                color: white;
                border: none;
                border-radius: 6px;
                cursor: pointer;
              ">
              Approve
            </button>

            <button
              type="button"
              style="
                padding: 10px 20px;
                background: #dc3545;
                color: white;
                border: none;
                border-radius: 6px;
                cursor: pointer;
              ">
              Reject
            </button>
          </div>
        </div>
      `;
    }

    viewContent.innerHTML = `
      <div class="bill-card">
        <div class="bill-left">

          <div class="info-row">
            <span>REFERENCE NO.</span>
            <strong>${referenceNumber}</strong>
          </div>

          <div class="info-row">
            <span>DUE DATE</span>
            <strong>${dueDate}</strong>
          </div>

          <div class="divider"></div>

          <div class="amount-row">
            <span>AMOUNT TO BE PAY</span>
            <div class="amount-value">
              ₱ ${amount}
            </div>
          </div>

        </div>

        <div class="bill-preview">
          ${
            file
              ? `
                <a href="/uploads/waterBills/${file}" target="_blank">
                  <iframe
                    src="/uploads/waterBills/${file}#toolbar=0&navpanes=0&scrollbar=0"
                    width="250"
                    height="250"
                    style="
                      border:none;
                      border-radius:12px;
                      background:white;
                      box-shadow:0 4px 10px rgba(0,0,0,0.15);
                      pointer-events:none;
                      display:block;
                    ">
                  </iframe>
                </a>
              `
              : '<p>No bill file uploaded.</p>'
          }
        </div>
      </div>

      ${approvalSection}
    `;

    tableBox.style.display = 'none';
    viewPanel.style.display = 'block';
  }

  function closeView() {
    document.getElementById('viewPanel').style.display = 'none';
    document.querySelector('.table-box').style.display = 'block';
  }

  function filterBills(status, clickedTab) {
    const rows = document.querySelectorAll('#tableBody tr');
    const tabs = document.querySelectorAll('.status-row .status');

    tabs.forEach(tab => tab.classList.remove('active'));
    clickedTab.classList.add('active');

    rows.forEach(row => {
      if (row.dataset.status === status) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }
</script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Upload Water Bill</title>

<style>
.container {
  display: flex;
}

.main {
  flex: 1;
  padding: 30px;
}

/* CARD */
.upload-card {
  background: #f4f4f4;
  border-radius: 20px;
  padding: 30px;
  box-shadow: 0 6px 14px rgba(0,0,0,0.15);
}

/* DROP AREA */
.drop-area {
  background: #0f3d00;
  border-radius: 15px;
  padding: 30px;
  color: white;
  text-align: center;
  cursor: pointer;
}

.drop-area input {
  display: none;
}

.drop-area p {
  margin-top: 10px;
  font-size: 13px;
}

/* PREVIEW */
.preview {
  margin-top: 20px;
  display: none;
}

.preview iframe {
  width: 100%;
  height: 400px;
  border-radius: 10px;
  border: 1px solid #ccc;
}

/* FORM */
.form-group {
  margin-top: 20px;
}

input[type="datetime-local"] {
  padding: 8px;
  border-radius: 10px;
  border: 1px solid #ccc;
}

.checkbox {
  margin-top: 15px;
}

/* BUTTON */
.upload-btn {
  margin-top: 20px;
  padding: 10px 30px;
  border: none;
  border-radius: 20px;
  background: #7CFF57;
  cursor: pointer;
  font-weight: bold;
}
</style>
</head>

<body>

<%- include('../../../partials/adminTopbar', { title: "Upload Water Bill" }) %>

<div class="container">

<%- include('../../../partials/adminSidebar', { page: 'memberships' }) %>

<div class="main">

  <div class="upload-card">

    <form action="/admin/bills/water/upload" method="POST" enctype="multipart/form-data">

      <!-- USER ID -->
      <input type="hidden" name="userId" value="<%= user._id %>">

      <!-- FILE UPLOAD -->
      <label class="drop-area">
        Click to select PDF
        <input type="file" name="bill" accept="application/pdf" required id="fileInput">

        <p id="fileName">No file selected</p>

        <p>
          Note: Click or drag the files (pdf) to upload.<br>
          Make sure the filename matches homeowner ref no.
        </p>
      </label>

      <!-- PDF PREVIEW -->
      <div class="preview" id="previewContainer">
        <h4>Preview:</h4>
        <iframe id="pdfPreview"></iframe>
      </div>

      <div class="form-group">
        <label>Enter Amount (₱):</label><br>
        <input type="number" name="amount" step="0.01" required>
      </div>

      <!-- DUE DATE -->
      <div class="form-group">
        <label>Enter Due Date:</label><br>
        <input type="datetime-local" name="dueDate" required>
      </div>

      <!-- CERTIFICATION -->
      <div class="checkbox">
        <input type="checkbox" required>
        I hereby certify that all information above is true and correct.
      </div>

      <!-- SUBMIT -->
      <button type="submit" class="upload-btn">Upload</button>

    </form>

  </div>

</div>

</div>

<script>
const fileInput = document.getElementById('fileInput');
const fileName = document.getElementById('fileName');
const preview = document.getElementById('pdfPreview');
const previewContainer = document.getElementById('previewContainer');

fileInput.addEventListener('change', function () {
  const file = this.files[0];

  if (!file) return;

  // show filename
  fileName.textContent = file.name;

  // preview PDF
  if (file.type === "application/pdf") {
    const fileURL = URL.createObjectURL(file);
    preview.src = fileURL;
    previewContainer.style.display = "block";
  } else {
    alert("Only PDF files are allowed.");
    fileInput.value = "";
    previewContainer.style.display = "none";
  }
});
</script>

</body>
</html>
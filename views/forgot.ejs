<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link rel="stylesheet" href="/css/forgotpass.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">

</head>
<body>

<!-- ✅ HEADER (INLINE, NO PARTIAL) -->
<div class="header">
  <div class="logo-container">
    <img src="/img/antel-logo.png" alt="">
  </div>
  <div class="page-title">FORGOT PASSWORD</div>
</div>

<div class="wrapper">

  <div class="inner-card">

    <div class="inner-header">
      FIND YOUR ACCOUNT
    </div>

    <div class="inner-content">

      <p>Enter your email address to find your account.</p>

      <input type="email" class="input-field" id="email" placeholder="Enter your email">
      <div class="error-message" id="emailError"></div>

      <div class="button-group">
        <button class="btn btn-red" onclick="clearEmail()">CLEAR</button>
        <button class="btn btn-green" onclick="sendOTP()">SEND OTP</button>
      </div>

      <p>Enter the 6 digits OTP sent to your email to reset your account.</p>

      <div class="otp-container">
        <input type="text" maxlength="1" class="otp-input">
        <input type="text" maxlength="1" class="otp-input">
        <input type="text" maxlength="1" class="otp-input">
        <input type="text" maxlength="1" class="otp-input">
        <input type="text" maxlength="1" class="otp-input">
        <input type="text" maxlength="1" class="otp-input">
      </div>

      <div class="resend">
        Resend OTP in <span id="timer">165</span> seconds...
      </div>

      <div class="verify-group">
        <button class="btn btn-red" onclick="cancelAction()">CANCEL</button>
        <button class="btn btn-green" onclick="verifyOTP()">VERIFY</button>
      </div>

    </div>

  </div>

</div>

<script>
let countdown;
let seconds = 165;

const timerEl = document.getElementById("timer");
const emailInput = document.getElementById("email");
const emailError = document.getElementById("emailError");

function clearEmail(){
  emailInput.value = "";
  emailInput.classList.remove("input-error");
  emailError.style.display = "none";
}

function isValidEmail(email){
  const pattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return pattern.test(email);
}

/* =========================
   SEND OTP (BACKEND CONNECTED)
========================= */
function sendOTP(){
  const email = emailInput.value.trim();

  if(email === ""){
    emailError.textContent = "Please fill in your email address.";
    emailError.style.display = "block";
    emailInput.classList.add("input-error");
    return;
  }

  if(!isValidEmail(email)){
    emailError.textContent = "Please enter a valid email address.";
    emailError.style.display = "block";
    emailInput.classList.add("input-error");
    return;
  }

  fetch("/send-otp", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ email })
  })
  .then(res => res.text())
  .then(data => {
    alert(data);

    // start timer
    clearInterval(countdown);
    seconds = 165;
    timerEl.textContent = seconds;

    countdown = setInterval(() => {
      seconds--;
      timerEl.textContent = seconds;

      if(seconds <= 0){
        clearInterval(countdown);
        timerEl.textContent = "0";
      }
    }, 1000);
  })
  .catch(err => {
    alert("Error sending OTP");
    console.error(err);
  });
}

/* =========================
   VERIFY OTP
========================= */
function verifyOTP(){
  const email = emailInput.value.trim();

  const inputs = document.querySelectorAll(".otp-input");
  let otp = "";
  inputs.forEach(i => otp += i.value);

  if(otp.length !== 6){
    alert("Please enter 6-digit OTP");
    return;
  }

  fetch("/verify-otp", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ email, otp })
  })
  .then(res => res.json())
  .then(data => {
    if(data.success){
      window.location.href = `/resetpass?email=${email}`;
    } else {
      alert(data.message || "Invalid OTP");
    }
  })
  .catch(err => {
    alert("Verification failed");
    console.error(err);
  });
}

/* =========================
   CANCEL
========================= */
function cancelAction(){
  window.location.href = "/login";
}

/* =========================
   OTP INPUT AUTO-JUMP (BONUS UX)
========================= */
const otpInputs = document.querySelectorAll(".otp-input");

otpInputs.forEach((input, index) => {
  input.addEventListener("input", () => {
    if(input.value.length === 1 && index < otpInputs.length - 1){
      otpInputs[index + 1].focus();
    }
  });

  input.addEventListener("keydown", (e) => {
    if(e.key === "Backspace" && !input.value && index > 0){
      otpInputs[index - 1].focus();
    }
  });
});
</script>

</body>
</html>
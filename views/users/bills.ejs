<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/topbar.css">
<link rel="stylesheet" href="/css/sidebar.css">
<link rel="stylesheet" href="/css/bills.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- ✅ TOPBAR -->
<%- include('../partials/userTopbar') %>

<div class="container">

  <!-- ✅ SIDEBAR -->
  <%- include('../partials/userSidebar') %>

  <!-- ✅ MAIN -->
  <div class="main">
    <div class="bills-container">

      <a href="/user/water-bill">
        <div class="bill-card">
          <div class="bill-image">
            <img src="/img/Water Bill.png" style="width:180px;">
          </div>
          <div class="bill-title">Water Bill</div>
        </div>
      </a>

      <a href="/user/due-bill">
        <div class="bill-card">
          <div class="bill-image">
            <img src="/img/Due Bill.png" style="width:180px;">
          </div>
          <div class="bill-title">Due Bill</div>
        </div>
      </a>

    </div>
  </div>

</div>

</body>
</html>
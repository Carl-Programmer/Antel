<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/topbar.css">
<link rel="stylesheet" href="/css/sidebar.css">
<link rel="stylesheet" href="/css/concerns.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- ✅ TOPBAR -->
<%- include('../partials/userTopbar') %>

<div class="container">

  <!-- ✅ SIDEBAR (logout is inside here already) -->
  <%- include('../partials/userSidebar') %>

  <!-- ✅ MAIN -->
  <div class="main">
    <div class="concern-card">

      <div class="concern-title">
        <img src="/img/concerns-logo.png">
        <span>Concerns</span>
      </div>

      <textarea class="concern-box" placeholder="Type your concern here..."></textarea>

      <button class="upload-btn">
        <img src="/img/upload-receipt-button.png">
        <span>Upload Files</span>
      </button>

      <div class="action-buttons">
        <button class="delete-btn">
          <img src="/img/delete-button.png">
        </button>
        <button class="next-btn">Next</button>
      </div>

      <!-- NOTE -->
      <p class="other-note">
        Others: Book an appointment with the AGV Property Management Admin for a personal visit.
        <a href="/user/appointments">Click here.</a>
      </p>

    </div>
  </div>

</div>

</body>
</html>
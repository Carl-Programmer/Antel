<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link rel="stylesheet" href="/css/userTopbar.css">
<link rel="stylesheet" href="/css/userSidebar.css">
<link rel="stylesheet" href="/css/gym-form2.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
.file-name {
  font-size: 12px;
  color: #333;
  margin-top: 5px;
}
</style>

</head>

<body>

<%- include('../partials/userTopbar', { title: title }) %>

<div class="container">

  <%- include('../partials/userSidebar', { page: 'memberships' }) %>

  <div class="main">

    <div class="membership-card featured-card">

      <div class="membership-header">
        <h3>Fitness Station</h3>
      </div>

      <div class="required">
        Required Documents (jpg/png/pdf only)
      </div>

      <form action="/user/gym-form2" method="POST" enctype="multipart/form-data">
        
        <!-- ✅ membership id -->
        <input type="hidden" name="membershipId" id="membershipId">

        <div class="upload-box">

          <!-- REQUIRED -->
          <div class="upload-row">
            <span>Membership Card (with signature)</span>
            <input type="file" name="membershipCard" id="file1" class="file-input" accept=".jpg,.jpeg,.png,.pdf" required>
            <label for="file1" class="upload-btn"><img src="/img/upload-receipt-button.png"></label>
            <div class="file-name" id="name1"></div>
          </div>

          <!-- REQUIRED -->
          <div class="upload-row">
            <span>Proof of Ownership</span>
            <input type="file" name="proofOfOwnership" id="file2" class="file-input" accept=".jpg,.jpeg,.png,.pdf" required>
            <label for="file2" class="upload-btn"><img src="/img/upload-receipt-button.png"></label>
            <div class="file-name" id="name2"></div>
          </div>

          <!-- TENANT OPTIONAL -->
          <div class="upload-row">
            <span>Endorsement Letter (Tenant only)</span>
            <input type="file" name="endorsementLetter" id="file3" class="file-input" accept=".jpg,.jpeg,.png,.pdf">
            <label for="file3" class="upload-btn"><img src="/img/upload-receipt-button.png"></label>
            <div class="file-name" id="name3"></div>
          </div>

          <!-- REQUIRED -->
          <div class="upload-row">
            <span>Valid I.D.</span>
            <input type="file" name="validId" id="file4" class="file-input" accept=".jpg,.jpeg,.png,.pdf" required>
            <label for="file4" class="upload-btn"><img src="/img/upload-receipt-button.png"></label>
            <div class="file-name" id="name4"></div>
          </div>

          <!-- TENANT OPTIONAL -->
          <div class="upload-row">
            <span>Contract of Lease (Tenant only)</span>
            <input type="file" name="contractOfLease" id="file5" class="file-input" accept=".jpg,.jpeg,.png,.pdf">
            <label for="file5" class="upload-btn"><img src="/img/upload-receipt-button.png"></label>
            <div class="file-name" id="name5"></div>
          </div>

        </div>

        <div class="certify">
          <input type="checkbox" required>
          <span>I certify that all information is true and correct.</span>
        </div>

        <div class="notes">
          Notes:<br>
          1. Information is confidential.<br>
          2. Dues must be updated before approval.
        </div>

        <div class="button-area">

          <button type="button" class="delete-btn" onclick="clearAll()">
            <img src="/img/delete-button.png" width="22">
          </button>

          <button type="submit" class="next-btn">Next</button>

        </div>

      </form>

    </div>

  </div>

</div>

<script>

// =============================
// MEMBERSHIP ID FROM URL
// =============================
const urlParams = new URLSearchParams(window.location.search);
const membershipId = urlParams.get('id');
if (membershipId) {
  document.getElementById('membershipId').value = membershipId;
}

// =============================
// SHOW FILE NAMES
// =============================
function handleFile(inputId, labelId){
  const input = document.getElementById(inputId);
  const label = document.getElementById(labelId);

  input.addEventListener("change", function(){
    if(input.files.length > 0){
      label.textContent = input.files[0].name;
    } else {
      label.textContent = "";
    }
  });
}

handleFile("file1","name1");
handleFile("file2","name2");
handleFile("file3","name3");
handleFile("file4","name4");
handleFile("file5","name5");

// =============================
// CLEAR ALL FILES
// =============================
function clearAll(){
  document.querySelectorAll('.file-input').forEach(input => input.value = "");
  document.querySelectorAll('.file-name').forEach(label => label.textContent = "");
}

</script>

</body>
</html>
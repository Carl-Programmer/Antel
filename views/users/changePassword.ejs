<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/topbar.css">
<link rel="stylesheet" href="/css/sidebar.css">
<link rel="stylesheet" href="/css/changePassword.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- ✅ TOPBAR -->
<%- include('../partials/userTopbar') %>

<div class="container">

  <!-- ✅ SIDEBAR -->
  <%- include('../partials/userSidebar') %>

  <!-- ✅ MAIN -->
  <div class="main">
    <div class="card">

      <h3>Change Password</h3>

      <div class="form-group">
        <label>Enter Current Password</label>
        <div class="password-wrapper">
          <input type="password" id="currentPass">
          <img src="/img/toggle-eye-button.png" class="toggle-eye" onclick="togglePass('currentPass')">
        </div>
      </div>

      <div class="form-group">
        <label>Enter New Password</label>
        <div class="password-wrapper">
          <input type="password" id="newPass">
          <img src="/img/toggle-eye-button.png" class="toggle-eye" onclick="togglePass('newPass')">
        </div>
      </div>

      <div class="form-group">
        <label>Confirm New Password</label>
        <div class="password-wrapper">
          <input type="password" id="confirmPass">
          <img src="/img/toggle-eye-button.png" class="toggle-eye" onclick="togglePass('confirmPass')">
        </div>

        <div class="password-hint-container">
          <img src="/img/note-logo.png" class="password-hint-icon">
          <div class="password-hint">
            A strong password should use at least 12 characters and include uppercase and lowercase letters,
            numbers, and symbols.
          </div>
        </div>
      </div>

      <div class="button-group">
        <button class="btn btn-cancel">CANCEL</button>
        <button class="btn btn-save">SAVE</button>
      </div>

    </div>
  </div>

</div>

<script>
function togglePass(id){
  const input = document.getElementById(id);
  input.type = input.type === "password" ? "text" : "password";
}
</script>

</body>
</html>
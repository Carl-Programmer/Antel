<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/topbar.css">
<link rel="stylesheet" href="/css/sidebar.css">
<link rel="stylesheet" href="/css/changePassword.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- TOPBAR -->
<%- include('../partials/userTopbar') %>

<div class="container">

  <!-- SIDEBAR -->
  <%- include('../partials/userSidebar') %>

  <!-- MAIN -->
  <div class="main">
    <div class="card">

      <h3>Change Password</h3>

      <!-- Success/Error Message -->
      <% if (message) { %>
        <div class="message">
          <%= message %>
        </div>
      <% } %>

      <!-- Change Password Form -->
      <form action="/users/change-password" method="POST">

        <!-- Current Password -->
        <div class="form-group">
          <label>Enter Current Password</label>
          <div class="password-wrapper">
            <input
              type="password"
              id="currentPass"
              name="currentPassword"
              required
            >
            <img
              src="/img/toggle-eye-button.png"
              class="toggle-eye"
              onclick="togglePass('currentPass')"
            >
          </div>
        </div>

        <!-- New Password -->
        <div class="form-group">
          <label>Enter New Password</label>
          <div class="password-wrapper">
            <input
              type="password"
              id="newPass"
              name="newPassword"
              minlength="12"
              required
            >
            <img
              src="/img/toggle-eye-button.png"
              class="toggle-eye"
              onclick="togglePass('newPass')"
            >
          </div>
        </div>

        <!-- Confirm New Password -->
        <div class="form-group">
          <label>Confirm New Password</label>
          <div class="password-wrapper">
            <input
              type="password"
              id="confirmPass"
              name="confirmPassword"
              minlength="12"
              required
            >
            <img
              src="/img/toggle-eye-button.png"
              class="toggle-eye"
              onclick="togglePass('confirmPass')"
            >
          </div>

          <div class="password-hint-container">
            <img src="/img/note-logo.png" class="password-hint-icon">
            <div class="password-hint">
              A strong password should use at least 12 characters and include
              uppercase and lowercase letters, numbers, and symbols.
            </div>
          </div>
        </div>

        <!-- Buttons -->
        <div class="button-group">
          <button
            type="button"
            class="btn btn-cancel"
            onclick="window.location.href='/users/dashboard'"
          >
            CANCEL
          </button>

          <button
            type="submit"
            class="btn btn-save"
          >
            SAVE
          </button>
        </div>

      </form>

    </div>
  </div>

</div>

<script>
function togglePass(id) {
  const input = document.getElementById(id);
  input.type = input.type === "password" ? "text" : "password";
}

// Strong password validation before submit
document.querySelector("form").addEventListener("submit", function(e) {
  const newPass = document.getElementById("newPass").value;
  const confirmPass = document.getElementById("confirmPass").value;

  const strongPasswordRegex =
    /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_\-+=\[{\]};:'",<.>\/?\\|`~]).{12,}$/;

  if (!strongPasswordRegex.test(newPass)) {
    e.preventDefault();
    alert(
      "Password must be at least 12 characters long and include:\n" +
      "- 1 uppercase letter\n" +
      "- 1 lowercase letter\n" +
      "- 1 number\n" +
      "- 1 special character"
    );
    return;
  }

  if (newPass !== confirmPass) {
    e.preventDefault();
    alert("Passwords do not match.");
  }
});
</script>

</body>
</html>